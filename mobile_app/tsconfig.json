{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ai": [
        "../ai_model/client/index.ts"
      ],
      "@ai/*": [
        "../ai_model/client/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../ai_model/client/**/*.ts"
  ]
}
